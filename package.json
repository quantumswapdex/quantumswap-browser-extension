{
  "name": "quantumswap-browser-extension",
  "displayName": "QuantumSwap Browser Extension",
  "version": "1.2.6",
  "private": true,
  "type": "module",
  "description": "QuantumSwap Browser Extension for Chrome and Firefox",
  "author": "QuantumSwap Community",
  "license": "MIT",
  "scripts": {
    "postinstall": "wxt prepare",
    "build:icons": "node scripts/build-icons.mjs",
    "build:bridge": "node scripts/build-bridge.mjs",
    "build": "npm run build:bridge && wxt build && wxt build -b firefox",
    "build:chrome": "npm run build:bridge && wxt build",
    "build:firefox": "npm run build:bridge && wxt build -b firefox",
    "build:all": "npm run build",
    "zip": "npm run build:bridge && wxt zip",
    "zip:firefox": "npm run build:bridge && wxt zip -b firefox"
  },
  "dependencies": {
    "quantumcoin": "^8.0.0",
    "quantumswap": "^1.0.0",
    "seed-words": "^1.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  }
}
